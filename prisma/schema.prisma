generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  onboarded     Boolean   @default(false)

  accounts          Account[]
  sessions          Session[]
  profile           Profile?
  cvDocuments       CVDocument[]
  applications      Application[]
  portalCredentials PortalCredential[]
  chatMessages      ChatMessage[]
  savedJobs         SavedJob[]
  gmailToken        GmailToken?
  emailTracking     EmailTracking[]
  atsAnalyses       ATSAnalysis[]
  reminders         Reminder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  phone           String?
  location        String?
  headline        String?
  summary         String?
  totalExperience Int?
  currentSalary   String?
  expectedSalary  String?
  noticePeriod    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  education     Education[]
  experience    Experience[]
  skills        Skill[]
  jobPreference JobPreference?
}

model Education {
  id          String  @id @default(cuid())
  profileId   String
  institution String
  degree      String
  field       String?
  startYear   Int?
  endYear     Int?
  grade       String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Experience {
  id          String    @id @default(cuid())
  profileId   String
  company     String
  title       String
  location    String?
  startDate   DateTime?
  endDate     DateTime?
  current     Boolean   @default(false)
  description String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Skill {
  id        String  @id @default(cuid())
  profileId String
  name      String
  level     String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model JobPreference {
  id              String  @id @default(cuid())
  profileId       String  @unique
  roles           String  @default("[]") // JSON array
  locations       String  @default("[]") // JSON array
  minSalary       Int?
  maxSalary       Int?
  jobType         String?
  remote          Boolean @default(false)
  industries      String  @default("[]") // JSON array
  experienceLevel String?

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model CVDocument {
  id          String   @id @default(cuid())
  userId      String
  filename    String
  filePath    String   @default("")
  fileType    String
  fileContent String?  // Base64 for uploads, markdown for generated
  parsedData  String?  // JSON string
  templateId  String?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Application {
  id           String   @id @default(cuid())
  userId       String
  jobTitle     String
  company      String
  jobUrl       String?
  portal       String
  status       String   @default("applied")
  appliedAt    DateTime @default(now())
  cvUsed       String?
  notes        String?
  coverLetter  String?  // AI-generated cover letter
  tailoredCV   String?  // AI-tailored CV markdown

  lastFollowUp   DateTime?
  followUpCount  Int       @default(0)
  nextFollowUpAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortalCredential {
  id       String @id @default(cuid())
  userId   String
  portal   String
  username String
  password String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, portal])
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String   // "user" or "assistant"
  content   String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedJob {
  id          String   @id @default(cuid())
  userId      String
  externalId  String?  // ID from job API
  title       String
  company     String
  location    String?
  salary      String?
  description String?
  url         String?
  source      String?  // "adzuna", "jsearch", etc.
  matchScore  Int?     // AI-calculated match percentage
  matchReason String?  // Why this job matches
  status      String   @default("new") // new, interested, applied, rejected
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model GmailToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  email        String   // Gmail address
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmailTracking {
  id            String   @id @default(cuid())
  userId        String
  applicationId String?
  gmailMsgId    String?  // Gmail message ID
  subject       String
  fromEmail     String
  snippet       String?  // Preview text
  category      String   // "interview_invite", "rejection", "follow_up", "offer", "other"
  parsedData    String?  // AI-parsed structured data (JSON)
  isRead        Boolean  @default(false)
  receivedAt    DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ATSAnalysis {
  id             String   @id @default(cuid())
  userId         String
  jobTitle       String?
  jobDescription String
  resumeContent  String
  score          Int
  analysis       String   // JSON: { keywords_found, keywords_missing, formatting_issues, suggestions, section_scores }
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Reminder {
  id            String    @id @default(cuid())
  userId        String
  applicationId String?
  type          String    // "follow_up", "interview_prep", "status_check"
  message       String
  dueAt         DateTime
  isDone        Boolean   @default(false)
  snoozedUntil  DateTime?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
